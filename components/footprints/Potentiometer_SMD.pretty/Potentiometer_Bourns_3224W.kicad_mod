  )
  (fp_text value Potentiometer_Bourns_3224W (at 0 3.2) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_line (start -2.4 -2.3) (end 2.4 -2.3) (layer F.Fab) (width 0.1))
  (fp_line (start 2.4 -2.3) (end 2.4 2.3) (layer F.Fab) (width 0.1))
  (fp_line (start 2.4 2.3) (end -2.4 2.3) (layer F.Fab) (width 0.1))
  (fp_line (start -2.4 2.3) (end -2.4 -2.3) (layer F.Fab) (width 0.1))
  (fp_line (start -4.2 -2.6) (end 4.2 -2.6) (layer F.CrtYd) (width 0.05))
  (fp_line (start 4.2 -2.6) (end 4.2 2.6) (layer F.CrtYd) (width 0.05))
  (fp_line (start 4.2 2.6) (end -4.2 2.6) (layer F.CrtYd) (width 0.05))
  (fp_line (start -4.2 2.6) (end -4.2 -2.6) (layer F.CrtYd) (width 0.05))
  (fp_line (start -2.4 -2.4) (end 2.4 -2.4) (layer F.SilkS) (width 0.12))
  (pad 1 smd roundrect (at -3.0 1.27) (size 2.0 1.0) (layers F.Cu F.Paste F.Mask) (roundrect_rratio 0.25))
  (pad 3 smd roundrect (at -3.0 -1.27) (size 2.0 1.0) (layers F.Cu F.Paste F.Mask) (roundrect_rratio 0.25))
  (pad 2 smd roundrect (at 3.0 0) (size 2.0 1.0) (layers F.Cu F.Paste F.Mask) (roundrect_rratio 0.25))
  (model ${KISYS3DMOD}/Potentiometer_SMD.3dshapes/Potentiometer_Bourns_3224W.wrl
