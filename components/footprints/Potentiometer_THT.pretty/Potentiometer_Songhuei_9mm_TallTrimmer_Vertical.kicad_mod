(module Potentiometer_Songhuei_9mm_TallTrimmer_Vertical (layer F.Cu) (tedit 20260530)
  (descr "Song Huei 9mm vertical tall trimmer potentiometer (Thonk ttpots). Footprint-compatible with the standard Taiwan Alpha 9mm vertical land pattern (RD901F-40): 3 signal pins at 2.5mm pitch + 2 body mounting legs. 6mm shaft. https://www.thonk.co.uk/shop/ttpots/")
  (tags "potentiometer vertical 9mm trimmer songhuei tall")
  (fp_text reference REF** (at 7.5 -5.2 0) (layer F.SilkS)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value Potentiometer_Songhuei_9mm_TallTrimmer_Vertical (at 7.5 7.8 0) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text user %R (at 7.5 2.5 0) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_line (start -1.15 9.17) (end 12.6 9.17) (layer F.CrtYd) (width 0.05))
  (fp_line (start -1.15 -4.17) (end -1.15 9.17) (layer F.CrtYd) (width 0.05))
  (fp_line (start 12.6 -4.17) (end -1.15 -4.17) (layer F.CrtYd) (width 0.05))
  (fp_line (start 12.6 9.17) (end 12.6 -4.17) (layer F.CrtYd) (width 0.05))
  (fp_circle (center 7.5 2.5) (end 12.35 2.5) (layer F.Fab) (width 0.1))
  (fp_circle (center 7.5 2.5) (end 12.45 2.5) (layer F.SilkS) (width 0.12))
  (fp_line (start -1.4 0) (end -1.4 0) (layer F.SilkS) (width 0.4))
  (pad 1 thru_hole rect (at 0 0 90) (size 1.8 1.8) (drill 1) (layers *.Cu *.Mask))
  (pad 2 thru_hole circle (at 0 2.5 90) (size 1.8 1.8) (drill 1) (layers *.Cu *.Mask))
  (pad 3 thru_hole circle (at 0 5 90) (size 1.8 1.8) (drill 1) (layers *.Cu *.Mask))
  (pad "" thru_hole circle (at 7.5 7.3 90) (size 3.24 3.24) (drill 1.8) (layers *.Cu *.Mask))
  (pad "" thru_hole circle (at 7.5 -2.3 90) (size 3.24 3.24) (drill 1.8) (layers *.Cu *.Mask))
)
