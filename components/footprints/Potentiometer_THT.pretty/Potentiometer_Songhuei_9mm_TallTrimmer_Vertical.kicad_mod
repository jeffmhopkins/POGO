(module Potentiometer_Songhuei_9mm_TallTrimmer_Vertical (layer F.Cu) (tedit 20260530)
  (descr "Song Huei R0904N 9mm snap-in insulated-shaft potentiometer (Thonk). Per datasheet PCB layout: 9.7mm SQUARE body centred on the shaft; 3 signal pins Ø1 at 2.5mm pitch on one edge, 2 snap-in mounting legs (2.2x1.8) on the opposite edge, 7mm pin-row to leg-row. Anchor = shaft (origin). https://www.thonk.co.uk/shop/ttpots/")
  (tags "potentiometer 9mm song huei R0904N snap-in vertical")
  (fp_text reference REF** (at 0 -5.8 0) (layer F.SilkS)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value Potentiometer_Songhuei_9mm_TallTrimmer_Vertical (at 0 5.8 0) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text user %R (at 0 0 0) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_line (start -6.5 -5.1) (end 6.5 -5.1) (layer F.CrtYd) (width 0.05))
  (fp_line (start 6.5 -5.1) (end 6.5 5.1) (layer F.CrtYd) (width 0.05))
  (fp_line (start 6.5 5.1) (end -6.5 5.1) (layer F.CrtYd) (width 0.05))
  (fp_line (start -6.5 5.1) (end -6.5 -5.1) (layer F.CrtYd) (width 0.05))
  (fp_line (start -4.85 -4.85) (end 4.85 -4.85) (layer F.Fab) (width 0.1))
  (fp_line (start 4.85 -4.85) (end 4.85 4.85) (layer F.Fab) (width 0.1))
  (fp_line (start 4.85 4.85) (end -4.85 4.85) (layer F.Fab) (width 0.1))
  (fp_line (start -4.85 4.85) (end -4.85 -4.85) (layer F.Fab) (width 0.1))
  (fp_line (start -4.85 -4.85) (end 4.85 -4.85) (layer F.SilkS) (width 0.12))
  (fp_line (start -4.85 4.85) (end 4.85 4.85) (layer F.SilkS) (width 0.12))
  (pad 1 thru_hole circle (at -2.5 3.5) (size 1.6 1.6) (drill 1) (layers *.Cu *.Mask))
  (pad 2 thru_hole circle (at 0 3.5) (size 1.6 1.6) (drill 1) (layers *.Cu *.Mask))
  (pad 3 thru_hole circle (at 2.5 3.5) (size 1.6 1.6) (drill 1) (layers *.Cu *.Mask))
  (pad "" thru_hole oval (at -5.3 -3.5) (size 2.2 1.8) (drill 1) (layers *.Cu *.Mask))
  (pad "" thru_hole oval (at 5.3 -3.5) (size 2.2 1.8) (drill 1) (layers *.Cu *.Mask))
)
