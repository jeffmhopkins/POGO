(module LED_D3.0mm (layer F.Cu) (tedit 5F5A1234)
  (descr "LED 3mm THT, vertical panel mount, origin at panel hole / LED body centre")
  (tags "LED 3mm THT panel mount Eurorack")
  (fp_text reference REF** (at 0 -2.5 180) (layer F.SilkS)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value LED_D3.0mm (at 0 5.5 180) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_line (start -2.0 -1.5) (end  2.0 -1.5) (layer F.CrtYd) (width 0.05))
  (fp_line (start  2.0 -1.5) (end  2.0  4.0) (layer F.CrtYd) (width 0.05))
  (fp_line (start  2.0  4.0) (end -2.0  4.0) (layer F.CrtYd) (width 0.05))
  (fp_line (start -2.0  4.0) (end -2.0 -1.5) (layer F.CrtYd) (width 0.05))
  (fp_circle (center 0 0) (end 1.5 0) (layer F.Fab)   (width 0.1))
  (fp_circle (center 0 0) (end 1.5 0) (layer F.SilkS) (width 0.12))
  (fp_line (start -1.06 -1.06) (end -1.06  1.06) (layer F.Fab) (width 0.1))
  (pad A thru_hole circle (at  1.27 2.54) (size 1.6 1.6) (drill 0.8) (layers *.Cu *.Mask))
  (pad K thru_hole circle (at -1.27 2.54) (size 1.6 1.6) (drill 0.8) (layers *.Cu *.Mask))
)
