  (pad 1 thru_hole circle (at  0     4.0) (size 2.0 2.0) (drill 1.2) (layers *.Cu *.Mask))
  (pad 2 thru_hole circle (at -2.54  6.0) (size 2.0 2.0) (drill 1.2) (layers *.Cu *.Mask))
  (pad 3 thru_hole circle (at  2.54  6.0) (size 2.0 2.0) (drill 1.2) (layers *.Cu *.Mask))
